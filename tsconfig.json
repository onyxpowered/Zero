{
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "NodeNext",
    "moduleResolution": "NodeNext",
    "lib":              ["ES2022"],
    "strict":           true,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "declaration":      true,
    "declarationMap":   true,
    "sourceMap":        true,
    "outDir":           "dist",
    "rootDir":          "."
  },
  "include": [
    "Engine/Dynamic/Startup/**/*",
    "Engine/Dynamic/Build/**/*",
    "Engine/Dynamic/Manage/Core/**/*",
    "Engine/Dynamic/CDN/**/*"
  ],
  "exclude": [
    "Engine/Dynamic/Manage/CLI",
    "Apps",
    "node_modules",
    "dist"
  ]
}
